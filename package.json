{
  "name": "golker-browser",
  "version": "1.0.0",
  "description": "O navegador mais leve e inteligente do mundo com IA integrada",
  "main": "src/index.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:deb": "electron-builder --linux deb",
    "build:appimage": "electron-builder --linux AppImage",
    "build:apk": "electron-builder --android apk",
    "build:all": "electron-builder --linux deb --linux AppImage --android apk"
  },
  "author": {
    "name": "Golker Team",
    "email": "hello@golker.dev"
  },
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "electron-log": "^5.0.0",
    "express": "^4.18.2",
    "llama-node": "^0.0.1"
  },
  "build": {
    "appId": "com.golker.browser",
    "productName": "Golker Browser",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Network"
    },
    "android": {
      "target": "apk",
      "packageName": "com.golker.browser"
    }
  }
}
